*.so
*.pyd
*.egg-info/
*.egg
dist/
build/
eggs/
*.whl
pip-wheel-metadata/
*.manifest
*.spec

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

