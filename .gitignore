# --- Visualization ---
*.png
*.jpg
*.jpeg
*.gif
*.mp4
*.avi
!docs/**/*.png
!docs/**/*.jpg
!docs/**/*.gif

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- OS ---
.DS_Store
Thumbs.db
*.tmp

